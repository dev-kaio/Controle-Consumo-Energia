# =============================================================
# Palm Energy — variáveis de ambiente
#
# Copie este arquivo para `.env` e preencha com os valores reais:
#     cp .env.example .env
#
# O arquivo `.env` NUNCA deve ser commitado (já está no .gitignore).
#
# Os valores FIREBASE_* vêm do arquivo JSON de conta de serviço:
#   Console Firebase > Configurações do projeto > Contas de serviço
#   > Gerar nova chave privada
# =============================================================

# --- Servidor ---
PORT=3000

# --- Firebase Admin (conta de serviço) ---
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_PRIVATE_KEY_ID=
# Cole a chave inteira entre aspas, mantendo os \n:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_UNIVERSE_DOMAIN=googleapis.com
FIREBASE_DATABASE_URL=https://seu-projeto-id-default-rtdb.firebaseio.com

# --- ESP32 ---
# Chave que a ESP envia no header x-api-key. Gere uma forte, ex:
#     openssl rand -hex 32
# e configure o MESMO valor no firmware (esp.cpp).
ESP_KEY=
